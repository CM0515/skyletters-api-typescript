# ─── BASE DE DATOS ───────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/skyletters"

# ─── SERVIDOR ────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ─── JWT ─────────────────────────────────────
JWT_SECRET=skyletters_super_secret_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=skyletters_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ─── SEGURIDAD ───────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── EMPRESA ─────────────────────────────────
EMPRESA_NOMBRE="CARTAS AL CIELO"
EMPRESA_NIT="900.123.456-7"
EMPRESA_CIUDAD="Bogotá, Colombia"
